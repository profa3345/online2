{
  "id": "/",
  "name": "ONLINE-ES – Eletroeletrônica",
  "short_name": "ONLINE-ES",
  "description": "Sistema de Relatórios de Atendimento Técnico – Online-ES Eletroeletrônica",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#f97316",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": ["business", "productivity"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://onlinees.vercel.app/manifest.json"
    }
  ],
  "scope_extensions": [
    { "origin": "https://onlinees.vercel.app" },
    { "origin": "https://*.onlinees.vercel.app" }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/pdf": [".pdf"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/png": [".png"]
      },
      "icons": [{ "src": "icons/icon-192x192.png", "sizes": "192x192" }],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+onlinees",
      "url": "./index.html?protocolo=%s"
    }
  ],
  "icons": [
